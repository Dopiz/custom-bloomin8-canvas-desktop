{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and hidden capture windows",
  "windows": ["main", "capture-*"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:tray:default",
    "core:menu:default",
    "notification:default",
    "autostart:default"
  ]
}
